{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/62ae463a-9f12-4edf-8544-4f6ca3834524/v2.0"
        }
      }
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.auth/*", "/assets/*", "/*.png", "/*.svg", "/*.ico", "/*.txt", "/*.json"]
  },
  "routes": [
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/dashboard",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/not-authorized.html",
      "statusCode": 403
    }
  }
}

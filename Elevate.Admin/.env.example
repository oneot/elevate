# Azure App Service Backend API
VITE_API_BASE_URL=

# Entra ID Authentication (테넌트 제한용)
# Tenant ID는 Azure Portal > Entra ID > Overview에서 확인
# 또는 Azure CLI: az account show --query tenantId -o tsv
VITE_AZURE_TENANT_ID=

# Client ID는 Terraform 적용 후 다음 명령으로 확인:
# cd infrastructure/terraform && terraform output entra_admin_app_id
VITE_AZURE_CLIENT_ID=

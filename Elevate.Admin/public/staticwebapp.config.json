{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "login": {
          "loginParameters": [
            "scope=openid profile api://c4ea0eaf-6aaa-42e0-85ff-eef864cd2728/access_as_user",
            "prompt=consent"
          ]
        },
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/62ae463a-9f12-4edf-8544-4f6ca3834524/v2.0",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET_APP_SETTING_NAME"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.auth/*", "*.{css,js,png,jpg,jpeg,gif,svg,ico,json}"]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "403": {
      "rewrite": "/not-authorized.html"
    }
  }
}

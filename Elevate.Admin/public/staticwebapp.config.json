{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET",
          "openIdConfigurationUrl": "https://login.microsoftonline.com/62ae463a-9f12-4edf-8544-4f6ca3834524/v2.0/.well-known/openid-configuration"
        },
        "login": {
          "scopes": ["openid", "profile", "email"]
        }
      }
    }
  },
  "globalValidationConfiguration": {
    "redirectToProvider": "aad",
    "unauthenticatedClientActions": ["Redirect302"]
  },
  "routes": [
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    },
    {
      "route": "/.auth/login/*",
      "serve": "/.auth/login/*",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [".js", ".css", ".jpg", ".png", ".gif", ".ico", "/.auth/*", "/.auth/me"]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
